# =============================================================================
# openSIS + Billing Module — Environment Variables
# Copy these into Railway: Project → Variables → Add Variable
# Railway auto-injects MYSQL* vars from the MySQL service — reference them here.
# =============================================================================

# ── Database (auto-provided by Railway MySQL service) ─────────────────────────
# These are set automatically when you add a MySQL service in Railway.
# You do NOT need to set these manually — they are listed here for reference.
#
# MYSQLHOST=
# MYSQLPORT=3306
# MYSQLDATABASE=railway
# MYSQLUSER=root
# MYSQLPASSWORD=

# ── Application ───────────────────────────────────────────────────────────────
# Your Railway-assigned URL (Settings → Networking → Public Domain)
APP_URL=https://your-app.up.railway.app

# ── Optional: Email (for invoice delivery) ───────────────────────────────────
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=your-sendgrid-api-key
# SMTP_FROM=billing@yourschool.edu
